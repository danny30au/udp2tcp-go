# /etc/config/udp2tcp
# UCI configuration for udp2tcp-go

# Client side: UDP→TCP (forward WireGuard UDP to a TCP endpoint)
config udp2tcp 'client'
	option enabled    0
	option listen     '127.0.0.1:51820'
	option remote     '203.0.113.1:51820'
	option reverse    0
	option threads    '4'
	option log_level  'info'

# Server side: TCP→UDP (receive TCP, forward to local WireGuard)
# config udp2tcp 'server'
# 	option enabled    0
# 	option listen     '0.0.0.0:51820'
# 	option remote     '127.0.0.1:51820'
# 	option reverse    1
# 	option threads    '4'
# 	option log_level  'info'
